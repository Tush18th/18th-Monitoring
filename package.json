{
  "name": "kpi-monitoring",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:simulation": "tsx scripts/e2e-simulation.ts",
    "dev:api": "npm run dev --prefix apps/api",
    "dev:dashboard": "npm run dev --prefix apps/dashboard",
    "dev:synthetic": "tsx apps/synthetic-agent/src/index.ts",
    "synthetic:run": "tsx apps/synthetic-agent/src/index.ts",
    "demo:seed": "tsx scripts/demo-http-seed.ts",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:dashboard\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "toxic-clean": "taskkill /F /IM node.exe /T || true"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0"
  }
}
