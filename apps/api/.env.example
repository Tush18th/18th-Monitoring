# ──────────────────────────────────────────────────────────────────────────────
# KPI Monitoring Platform — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env files to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_at_least_64_char_random_string
JWT_EXPIRES_IN=8h

# ── PostgreSQL (Drizzle ORM) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/kpi_monitoring
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis (Phase 4 medium-term — uncomment when Redis is added) ───────────────
# REDIS_URL=redis://localhost:6379
# REDIS_TLS=false

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_MAX_ENTRIES=2000
TTL_RESOLVED_CONFIG=300
TTL_METRIC_CATALOG=600
TTL_KPI_QUERY=30
TTL_WIDGET=60
TTL_INTEGRATION_STATUS=15

# ── Idempotency ───────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_MS=86400000

# ── CSV Import Limits ─────────────────────────────────────────────────────────
CSV_MAX_MB=10
CSV_MAX_ROWS=50000
CSV_CHUNK_SIZE=500

# ── DLQ / Retry ───────────────────────────────────────────────────────────────
DLQ_MAX_ATTEMPTS=5

# ── Connector Vault (point to secret manager in production) ──────────────────
# SECRET_MANAGER=aws_ssm              # aws_ssm | gcp_secret_manager | hashicorp_vault
# AWS_REGION=eu-west-1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC_MAX=20
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_INGEST_MAX=500
RATE_LIMIT_INGEST_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=100
RATE_LIMIT_ADMIN_WINDOW_MS=60000

# ── Observability / APM ───────────────────────────────────────────────────────
# DATADOG_API_KEY=
# SENTRY_DSN=
# LOG_LEVEL=info
