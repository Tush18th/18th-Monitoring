{
  "metrics": [
    {
      "metricKey": "ORDER_VELOCITY",
      "description": "Rate of successful orders placed over an interval",
      "type": "count",
      "aggregation": "sum",
      "filters": {
        "status": ["placed", "processed"]
      },
      "groupBy": ["orderSource"],
      "granularity": "1m",
      "unit": "orders/min"
    },
    {
      "metricKey": "REVENUE_ONLINE",
      "description": "Total gross revenue generated by online sources",
      "type": "value",
      "aggregation": "sum",
      "field": "amount",
      "filters": {
        "orderSource": ["online"]
      },
      "granularity": "1h",
      "unit": "currency"
    },
    {
      "metricKey": "ORDERS_UNCLASSIFIED",
      "description": "Orders that failed orderSource classification and fell back to default",
      "type": "count",
      "aggregation": "sum",
      "filters": {
        "orderSource": ["unknown"]
      },
      "groupBy": ["sourceSystem"],
      "granularity": "1h",
      "unit": "orders",
      "alert": { "threshold": 10, "operator": "gt", "severity": "warn" }
    },
    {
      "metricKey": "ORDERS_DUPLICATE_REJECTED",
      "description": "Orders rejected by the deduplication guard during ingestion",
      "type": "count",
      "aggregation": "sum",
      "filters": {},
      "groupBy": ["connectorId"],
      "granularity": "1h",
      "unit": "orders",
      "alert": { "threshold": 20, "operator": "gt", "severity": "warn" }
    },
    {
      "metricKey": "ORDERS_SYNC_FAILURES",
      "description": "Count of sync operations that resulted in a FAILED status in sync_logs",
      "type": "count",
      "aggregation": "sum",
      "filters": {
        "status": ["FAILED"]
      },
      "groupBy": ["connectorId"],
      "granularity": "15m",
      "unit": "syncs",
      "alert": { "threshold": 1, "operator": "gt", "severity": "critical" }
    },
    {
      "metricKey": "ORDERS_IMPORT_LATENCY",
      "description": "P95 end-to-end latency from raw payload acceptance to normalized order write",
      "type": "value",
      "aggregation": "avg",
      "field": "processingMs",
      "filters": {},
      "groupBy": ["connectorId"],
      "granularity": "5m",
      "unit": "ms",
      "alert": { "threshold": 30000, "operator": "gt", "severity": "warn" }
    },
    {
      "metricKey": "ORDERS_RECONCILIATION_VARIANCE",
      "description": "Delta between expected order count from connector and canonical order count",
      "type": "value",
      "aggregation": "sum",
      "field": "varianceCount",
      "filters": {},
      "groupBy": ["connectorId"],
      "granularity": "1d",
      "unit": "orders",
      "alert": { "threshold": 5, "operator": "gt", "severity": "critical" }
    }
  ]
}
